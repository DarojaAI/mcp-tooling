# Duffel MCP Server Configuration
# Copy this to /etc/mcp-tooling/secrets.env and fill in real values

# Duffel API credentials
DUFFEL_API_KEY=duffel_test_***
DUFFEL_API_URL=https://api.duffel.com

# MCP tooling security
MCPTOOLING_ALLOWED_TOKENS=token1,token2,token3

# Safety gates (set to 'true' to enable destructive operations)
MCPTOOLING_CONFIRM_BOOKING=false
MCPTOOLING_CONFIRM_DESTRUCTIVE=false
