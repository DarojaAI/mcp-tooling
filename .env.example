# Environment variables for mcp-tooling deployment
# Copy this to .env for local work, or configure in GitHub Actions Secrets for CI/CD

# ====================================
# Required GitHub Actions Secrets
# ====================================
# Set these in: Settings → Secrets and variables → Actions → Repository secrets

# Hetzner Cloud API token (used by terraform + hcloud-cli)
HETZNER_API_TOKEN=hcloud_***

# S3 access key for Terraform state backend
HCX_ACCESS_KEY=***

# S3 secret key for Terraform state backend
HCX_SECRET_KEY=***

# ED25519 private key (no passphrase) for SSH access to the VM
SSH_PRIVATE_KEY=|
  -----BEGIN OPENSSH PRIVATE KEY-----
  ***
  -----END OPENSSH PRIVATE KEY-----

# Duffel API key (sandbox or production)
DUFFEL_API_KEY=duffel_***

# Comma-separated bearer tokens for MCP client allowlist. May include
# hand-minted global tokens; per-agent tokens (derived from the salt
# + bindings JSON below) are appended automatically at deploy time.
MCPTOOLING_ALLOWED_TOKENS=token1,token2

# HMAC-SHA256 salt used to derive per-agent bearer tokens at deploy
# time. Required only when MCPTOOLING_AGENT_BINDINGS_JSON is non-empty.
# Rotate by changing the salt and redeploying.
MCPTOOLING_AGENT_TOKEN_SALT=replace-with-strong-random-secret

# Per-agent MCP server allowlist (JSON). Mirrors the linux-desktop-seed
# PR #908 binding map. Each entry produces one derived bearer token per
# listed (agent, server) pair; the wildcard "*" becomes "<server>_default".
#   Example:
#     [{"agent":"trip_planning","servers":["duffel"]},
#      {"agent":"*","servers":["duffel"]}]
# Leave as "[]" to skip per-agent token minting (global tokens still work).
MCPTOOLING_AGENT_BINDINGS_JSON=[]

# ====================================
# Required GitHub Actions Environment Variables
# ====================================
# Set these in: Settings → Environments → <environment> → Environment variables

# Hetzner server hostname for the duffel MCP server
# Default: mcp-duffel-dev
SERVER_NAME=mcp-duffel-dev

# Hetzner datacenter location (hel1, fsn1, nbg1)
# Default: hel1
HETZNER_LOCATION=hel1

# Hetzner server type (cx22 = 2 vCPU, 4GB RAM)
# Default: cx22
SERVER_TYPE=cx22

# SSH key name registered in Hetzner project
HETZNER_SSH_KEY_NAME=your-ssh-key-name

# Hetzner Object Storage endpoint URL (e.g., https://hel1.your-objectstorage.com/).
# The deploy workflow extracts the region (hel1/fsn1/nbg1) from this URL.
HCX_STORAGE_URL=https://hel1.your-objectstorage.com/

# Note: Terraform state bucket + key are derived inside the infra-actions
# reusable from `repo_name` + HCX_STORAGE_URL. No env vars required.
