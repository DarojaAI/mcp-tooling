# Google Workspace MCP Server Configuration
# Copy this to /etc/mcp-tooling/secrets.env and fill in real values
#
# This server is narrow-scope by design. Only the two OAuth scopes
# in ALLOWED_SCOPES (servers/google_workspace/scope_guard.py) are
# permitted. Anything else will cause the server to refuse to start.
#
# See docs/integrations/google-workspace-mcp.md for the OAuth bootstrap
# procedure.

# --- Google OAuth client ---
GOOGLE_WORKSPACE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_WORKSPACE_CLIENT_SECRET=***
GOOGLE_WORKSPACE_REFRESH_TOKEN=

# --- Optional overrides ---
# If unset, the server uses the narrow allowlist (drive.file + documents).
# If set, every scope MUST be in ALLOWED_SCOPES — see scope_guard.py.
# GOOGLE_WORKSPACE_SCOPES=https://www.googleapis.com/auth/drive.file,https://www.googleapis.com/auth/documents

# GOOGLE_WORKSPACE_PROJECT_ID=my-google-cloud-project   # diagnostics only

# --- MCP tooling security ---
MCPTOOLING_ALLOWED_TOKENS=token1,token2,token3