# Amadeus Hotels MCP Server Configuration
# Copy this to /etc/mcp-tooling/secrets.env and fill in real values.
#
# Free Self-Service credentials: https://developers.amadeus.com
#
# The client uses OAuth2 client credentials and auto-refreshes its
# access token. No refresh token to rotate — just rotate the client
# secret in the Amadeus dashboard if needed.

# --- Amadeus OAuth client credentials ---
AMADEUS_CLIENT_ID=your_client_id
AMADEUS_CLIENT_SECRET=***
# Optional: "test" (default) or "production". Test env uses
# https://test.api.amadeus.com and includes free test datasets
# (LON, NYC, etc.) for hotels.
AMADEUS_ENV=test

# --- MCP tooling security ---
MCPTOOLING_ALLOWED_TOKENS=token1,token2,token3