# Environment variables for mcp-tooling deployment
# Copy this to .env for local work, or configure in GitHub Actions Secrets for CI/CD

# ====================================
# Required GitHub Actions Secrets
# ====================================
# Set these in: Settings → Secrets and variables → Actions → Repository secrets

# Hetzner Cloud API token (used by terraform + hcloud-cli)
HETZNER_API_TOKEN=hcloud_***

# S3 access key for Terraform state backend
HCX_ACCESS_KEY=***

# S3 secret key for Terraform state backend
HCX_SECRET_KEY=***

# ED25519 private key (no passphrase) for SSH access to the VM
SSH_PRIVATE_KEY=|
  -----BEGIN OPENSSH PRIVATE KEY-----
  ***
  -----END OPENSSH PRIVATE KEY-----

# Duffel API key (sandbox or production)
DUFFEL_API_KEY=duffel_***

# Comma-separated bearer tokens for MCP client allowlist
MCPTOOLING_ALLOWED_TOKENS=token1,token2

# ====================================
# Required GitHub Actions Environment Variables
# ====================================
# Set these in: Settings → Environments → <environment> → Environment variables

# Hetzner server hostname for the duffel MCP server
# Default: mcp-duffel-dev
SERVER_NAME=mcp-duffel-dev

# Hetzner datacenter location (hel1, fsn1, nbg1)
# Default: hel1
HETZNER_LOCATION=hel1

# Hetzner server type (cx22 = 2 vCPU, 4GB RAM)
# Default: cx22
SERVER_TYPE=cx22

# SSH key name registered in Hetzner project
HETZNER_SSH_KEY_NAME=your-ssh-key-name

# S3-compatible endpoint for Terraform state (e.g., s3.us-west-1.amazonaws.com)
HCX_STORAGE_URL=s3.us-west-1.amazonaws.com

# S3 bucket name for Terraform state
TERRAFORM_STATE_BUCKET=your-terraform-state-bucket

# S3 key path for Terraform state file
# Default: mcp-tooling/duffel/terraform.tfstate
TERRAFORM_STATE_KEY=mcp-tooling/duffel/terraform.tfstate
